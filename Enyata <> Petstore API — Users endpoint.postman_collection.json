      "name": "1. Create User",
      "item": [
        {
          "name": "POST /user — Create a new user (valid payload)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has correct content-type', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response body contains code 200', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('code');",
                  "    pm.expect(json.code).to.eql(200);",
                  "});",
                  "",
                  "pm.test('Response body contains type ok', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.type).to.eql('unknown');",
                  "});",
                  "",
                  "pm.test('Response time is under 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
