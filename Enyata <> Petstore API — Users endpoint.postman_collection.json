    {
      "name": "3. Get User",
      "item": [
        {
          "name": "GET /user/{username} — Get existing user by username",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is valid JSON with all required fields', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('username');",
                  "    pm.expect(json).to.have.property('firstName');",
                  "    pm.expect(json).to.have.property('lastName');",
                  "    pm.expect(json).to.have.property('email');",
                  "    pm.expect(json).to.have.property('phone');",
                  "    pm.expect(json).to.have.property('userStatus');",
                  "});",
                  "",
                  "pm.test('Username in response matches request', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.username).to.eql(pm.collectionVariables.get('testUsername'));",
                  "});",
                  "",
                  "pm.test('id is a number', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Response time is under 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{testUsername}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{testUsername}}"
              ]
            }
          },
          "response": []
        },
