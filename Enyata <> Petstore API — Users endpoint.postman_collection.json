    {
      "name": "2. Login & Logout",
      "item": [
        {
          "name": "GET /user/login — Login with valid credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains session token in body', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.message).to.include('logged in user session:');",
                  "    // Extract token and save to variable for later use",
                  "    var token = json.message.split(':')[1].trim();",
                  "    pm.collectionVariables.set('authToken', token);",
                  "    console.log('Auth token saved:', token);",
                  "});",
                  "",
                  "pm.test('Response has X-Rate-Limit-Limit header', function () {",
                  "    pm.expect(pm.response.headers.has('X-Rate-Limit-Limit')).to.be.true;",
                  "});",
                  "",
                  "pm.test('Response has X-Expires-After header', function () {",
                  "    pm.expect(pm.response.headers.has('X-Expires-After')).to.be.true;",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response time is under 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/login?username={{testUsername}}&password={{testPassword}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "login"
              ],
              "query": [
                {
                  "key": "username",
                  "value": "{{testUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{testPassword}}"
                }
              ]
            }
          },
          "response": []
        },
